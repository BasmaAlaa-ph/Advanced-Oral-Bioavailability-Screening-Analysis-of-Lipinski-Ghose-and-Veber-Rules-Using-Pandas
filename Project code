clean_df = df[['Molecular Formula', 'XLogP', 'Molecular Weight',
               'Hydrogen Bond Donors', 'Hydrogen Bond Acceptors',
               'SMILES', 'Element Count' ,'Topological Polar Surface Area',
               'Rotatable Bonds Count']].copy()

